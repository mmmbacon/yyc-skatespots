# Copy to client/.env — these are public build-time values (Vite embeds VITE_* in the bundle).

VITE_GRAPHQL_HTTP_URL=http://localhost:4000/graphql
VITE_GRAPHQL_WS_URL=ws://localhost:4000/graphql

# Must match OAUTH_CLIENT_ID in the root .env
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Mapbox public token — https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your-mapbox-public-token
