{
  "name": "skatespot.app",
  "version": "1.0.0",
  "description": "Skate spot map — GraphQL API",
  "main": "server.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore client/ server.js",
    "db:up": "docker compose up -d mongodb",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mongodb",
    "db:seed": "node scripts/seed.js",
    "test": "node --test tests/*.test.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@graphql-tools/schema": "^10.0.16",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "bcryptjs": "^2.4.3",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.2",
    "graphql": "^16.10.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^5.16.2",
    "mongoose": "^8.9.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2"
  }
}
