# Copy to .env in the project root and fill in real values.
# Backend only — the React app in client/ does not load this file.

# MongoDB — use ONE of the following:

# Local Docker (from repo root: npm run db:up)
MONGO_URI=mongodb://127.0.0.1:27017/skatespots

# MongoDB Atlas
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/skatespots?retryWrites=true&w=majority

# Google OAuth 2.0 Web client ID — must match VITE_GOOGLE_CLIENT_ID in client/.env
# https://console.cloud.google.com/apis/credentials
OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com

# GraphQL / Apollo server port (optional; defaults to 4000)
PORT=4000
